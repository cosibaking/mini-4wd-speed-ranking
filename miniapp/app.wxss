@import './styles/variables.wxss';

page {
  background-color: var(--color-bg);
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: var(--spacing-page);
  padding-bottom: calc(var(--spacing-page) + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.card--flat {
  box-shadow: none;
  border: 1rpx solid var(--color-border);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  line-height: 1.4;
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--color-text);
}

.text-secondary {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.lap-time {
  font-family: 'Courier New', Consolas, monospace;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.rank-gold { color: #D4A017; }
.rank-silver { color: #A8A8A8; }
.rank-bronze { color: #CD7F32; }

.loading-tip {
  text-align: center;
  padding: 48rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.icon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 22rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.link {
  color: var(--color-primary);
}
