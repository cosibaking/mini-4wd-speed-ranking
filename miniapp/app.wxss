@import './styles/variables.wxss';

page {
  background-color: var(--color-bg);
  color: var(--color-text);
  font-size: 28rpx;
  line-height: 1.5;
}

.container {
  padding: var(--spacing-page);
  padding-bottom: calc(var(--spacing-page) + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* 内容区预留底部空间，避免被固定操作栏遮挡 */
.container--action-bar {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.container--action-bar-lg {
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
}

/* 底部固定操作栏：按钮常驻屏幕底部，短页面不再大片留白 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  gap: 16rpx;
  padding: 16rpx var(--spacing-page);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-card);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.action-bar--column {
  flex-direction: column;
}

.action-bar__btn {
  flex: 1;
  margin: 0;
}

.action-bar__row {
  display: flex;
  gap: 16rpx;
}

.action-bar__hint {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.card--flat {
  box-shadow: none;
  border: 1rpx solid var(--color-border);
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
  color: #fff;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  line-height: 1.4;
}

.btn-secondary::after {
  border: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: var(--color-text);
}

.text-secondary {
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

.lap-time {
  font-family: 'Courier New', Consolas, monospace;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.rank-gold { color: #D4A017; }
.rank-silver { color: #A8A8A8; }
.rank-bronze { color: #CD7F32; }

.loading-tip {
  text-align: center;
  padding: 48rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.icon-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: 22rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.link {
  color: var(--color-primary);
}
