/* 全局设计变量 */
page {
  --color-primary: #E85D04;
  --color-primary-light: #FB923C;
  --color-primary-dark: #C2410C;
  --color-primary-bg: #FFF7ED;
  --color-text: #1A1A1A;
  --color-text-secondary: #666666;
  --color-text-placeholder: #999999;
  --color-border: #E8E8E8;
  --color-bg: #FAF8F5;
  --color-card: #FFFFFF;
  --radius-card: 16rpx;
  --radius-btn: 12rpx;
  --radius-pill: 999rpx;
  --spacing-page: 32rpx;
  --shadow-card: 0 4rpx 20rpx rgba(232, 93, 4, 0.08);
  --shadow-float: 0 8rpx 24rpx rgba(232, 93, 4, 0.22);
  --tab-bar-height: 100rpx;
}
