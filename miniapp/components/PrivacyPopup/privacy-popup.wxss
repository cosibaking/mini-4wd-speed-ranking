.privacy-mask {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(0, 0, 0, 0.55);
}

.privacy-dialog {
  width: 100%;
  max-width: 620rpx;
  padding: 40rpx 36rpx 32rpx;
  border-radius: 24rpx;
  background: #fff;
}

.privacy-title {
  margin-bottom: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1208;
  text-align: center;
}

.privacy-content {
  font-size: 28rpx;
  line-height: 1.7;
  color: #666;
}

.privacy-link {
  color: #e85d04;
}

.privacy-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 36rpx;
}

.privacy-btn {
  flex: 1;
  height: 80rpx;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  line-height: 80rpx;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn--ghost {
  color: #666;
  background: #f5f5f5;
}

.privacy-btn--primary {
  color: #fff;
  background: linear-gradient(135deg, #f48c06, #e85d04);
}
