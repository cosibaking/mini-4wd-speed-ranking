.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-state__img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 28rpx;
  opacity: 0.85;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: var(--color-text);
}

.empty-state__desc {
  text-align: center;
  margin-bottom: 36rpx;
  line-height: 1.6;
  max-width: 480rpx;
}

.empty-state__btn {
  width: 320rpx;
}
