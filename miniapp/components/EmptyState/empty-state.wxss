.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-state__icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-state__title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-state__desc {
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-state__btn {
  width: 320rpx;
}
