.post-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.post-card__title {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
  line-height: 1.4;
}

.post-card__summary {
  display: block;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.5;
}

.post-card__cover {
  width: 100%;
  height: 280rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: var(--color-border);
}

.post-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border);
}

.post-card__author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.post-card__avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-border);
  flex-shrink: 0;
}

.post-card__stats {
  display: flex;
  gap: 24rpx;
  flex-shrink: 0;
}

.post-card__stat {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
