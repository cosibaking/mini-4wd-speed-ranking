<view class="record-row {{highlight ? 'record-row--highlight' : ''}}" bindtap="onTap">
  <view class="record-row__rank {{entry.rank <= 3 ? 'rank-' + entry.rank : ''}}">
    <text>{{entry.rank}}</text>
  </view>
  <image class="record-row__avatar" src="{{entry.user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
  <view class="record-row__info">
    <text class="record-row__name">{{entry.user.nickName}}</text>
  </view>
  <text class="record-row__time lap-time">{{entry.lapTimeDisplay}}</text>
  <text class="record-row__arrow">›</text>
</view>
