.record-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.record-row--highlight {
  background: #E8F5E9;
}

.record-row__rank {
  width: 48rpx;
  text-align: center;
  font-weight: 700;
  font-size: 30rpx;
  color: var(--color-text-secondary);
}

.record-row__rank.rank-1 { color: #D4A017; }
.record-row__rank.rank-2 { color: #A8A8A8; }
.record-row__rank.rank-3 { color: #CD7F32; }

.record-row__avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin: 0 16rpx;
  background: var(--color-border);
}

.record-row__info {
  flex: 1;
}

.record-row__name {
  font-size: 28rpx;
}

.record-row__time {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.record-row__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
}
