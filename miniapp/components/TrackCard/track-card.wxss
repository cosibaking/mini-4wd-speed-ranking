.track-card {
  position: relative;
  overflow: hidden;
  padding: 0;
  background: var(--color-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.track-card__accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, var(--color-primary-light), var(--color-primary));
}

.track-card__body {
  padding: 24rpx 24rpx 24rpx 28rpx;
}

.track-card__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.track-card__name {
  font-size: 30rpx;
  font-weight: 600;
  flex: 1;
  padding-right: 16rpx;
  color: var(--color-text);
  white-space: normal;
  word-break: break-all;
  line-height: 1.4;
}

.track-card__arrow {
  color: var(--color-text-placeholder);
  font-size: 36rpx;
  flex-shrink: 0;
  line-height: 1.2;
}

.track-card__meta {
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
}

.track-card__pin {
  margin-right: 6rpx;
  font-size: 22rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.track-card__meta-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  white-space: normal;
  word-break: break-all;
}

.track-card__footer {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border);
}

.track-card__footer--empty {
  border-top: none;
  padding-top: 0;
}

.track-card__record {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  width: 100%;
}

.track-card__badge {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-pill);
  flex-shrink: 0;
}

.track-card__time {
  font-family: 'Courier New', Consolas, monospace;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.track-card__nick {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: normal;
  word-break: break-all;
  line-height: 1.4;
}

.track-card__count {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.track-card__empty {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

/* 首页深色底上的卡片 */
.track-card--dark {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: none;
}

.track-card--dark .track-card__name {
  color: #ffffff;
}

.track-card--dark .track-card__arrow {
  color: rgba(255, 255, 255, 0.45);
}

.track-card--dark .track-card__meta-text,
.track-card--dark .track-card__nick,
.track-card--dark .track-card__count,
.track-card--dark .track-card__empty {
  color: rgba(255, 255, 255, 0.78);
}

.track-card--dark .track-card__footer {
  border-top-color: rgba(255, 255, 255, 0.16);
}

.track-card--dark .track-card__badge {
  color: #ffffff;
  background: var(--color-primary);
}

.track-card--dark .track-card__time {
  color: var(--color-primary-light);
}
