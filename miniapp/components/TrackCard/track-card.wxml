<view class="track-card card" bindtap="onTap">
  <view class="track-card__header">
    <text class="track-card__name">{{track.name}}</text>
    <text class="track-card__arrow">›</text>
  </view>
  <view class="track-card__meta text-secondary">
    <text wx:if="{{showDistance && distanceText}}">{{distanceText}} · </text>
    <text>{{track.organizerName}}</text>
  </view>
  <view class="track-card__footer" wx:if="{{track.topRecord}}">
    <text class="text-secondary">Top1 </text>
    <text class="lap-time">{{track.topRecord.lapTimeDisplay}}</text>
    <text class="text-secondary"> · {{track.topRecord.nickName}}</text>
    <text class="text-secondary track-card__count"> · {{track.participantCount}}人入榜</text>
  </view>
  <view class="track-card__footer" wx:else>
    <text class="text-secondary">还没有人挑战</text>
  </view>
</view>
