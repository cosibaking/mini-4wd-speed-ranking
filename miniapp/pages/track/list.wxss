.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-bar__input {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-btn);
  padding: 16rpx 24rpx;
  border: 2rpx solid var(--color-border);
}

.search-bar__btn {
  background: var(--color-primary) !important;
  color: #fff !important;
}

.loading-tip {
  text-align: center;
  padding: 32rpx;
}
