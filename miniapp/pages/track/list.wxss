.page-head {
  margin-bottom: 24rpx;
}

.page-head__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  display: block;
}

.page-head__desc {
  display: block;
  margin-top: 8rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card);
}

.search-bar__icon {
  font-size: 28rpx;
  opacity: 0.5;
}

.search-bar__input {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
  background: transparent;
}

.search-bar__btn {
  background: var(--color-primary) !important;
  color: #fff !important;
  border-radius: var(--radius-pill) !important;
  padding: 0 32rpx !important;
  font-size: 26rpx !important;
  line-height: 64rpx !important;
  margin: 0 !important;
}
