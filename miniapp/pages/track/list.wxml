<view class="container">
  <view class="search-bar">
    <input
      class="search-bar__input"
      placeholder="搜索赛道名称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button class="search-bar__btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <block wx:if="{{tracks.length > 0}}">
    <track-card wx:for="{{tracks}}" wx:key="id" track="{{item}}" />
  </block>

  <empty-state
    wx:if="{{!loading && tracks.length === 0}}"
    title="暂无赛道"
    desc="成为第一个创建赛道的主理人吧"
    actionText="创建赛道"
    bind:action="onCreateTrack"
  />

  <view class="loading-tip text-secondary" wx:if="{{loading}}">加载中…</view>
</view>
