<view class="container track-list-page">
  <view class="page-head">
    <text class="page-head__title">选择赛道</text>
    <text class="page-head__desc text-secondary">找到附近的公园赛道，开始挑战圈速</text>
  </view>

  <view class="search-bar">
    <text class="search-bar__icon">🔍</text>
    <input
      class="search-bar__input"
      placeholder="搜索赛道名称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearch"
    />
    <button class="search-bar__btn" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <block wx:if="{{tracks.length > 0}}">
    <track-card wx:for="{{tracks}}" wx:key="id" track="{{item}}" />
  </block>

  <empty-state
    wx:if="{{!loading && tracks.length === 0}}"
    title="暂无赛道"
    desc="成为第一个创建赛道的主理人吧"
    actionText="创建赛道"
    bind:action="onCreateTrack"
  />

  <view class="loading-tip" wx:if="{{loading}}">加载中…</view>
</view>
