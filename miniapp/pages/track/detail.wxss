.detail-card {
  background: linear-gradient(135deg, #fff 0%, var(--color-primary-bg) 100%);
  padding: 32rpx 28rpx;
}

.detail-card__header {
  margin-bottom: 8rpx;
}

.detail-card__header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-card__name {
  font-size: 38rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
  color: var(--color-primary-dark);
  flex: 1;
  min-width: 0;
}

.detail-card__arrow {
  font-size: 36rpx;
  color: var(--color-text-placeholder);
  flex-shrink: 0;
  margin-bottom: 16rpx;
}

.detail-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.detail-card__hint {
  display: block;
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.detail-card__info {
  padding: 8rpx 0 24rpx;
  margin-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(232, 93, 4, 0.12);
}

.detail-info-item {
  margin-bottom: 24rpx;
}

.detail-info-item:last-child {
  margin-bottom: 0;
}

.detail-info-item__label {
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.detail-info-item__value {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.detail-info-empty {
  padding: 24rpx 0;
  text-align: center;
}

.detail-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: #fff;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.detail-card__section {
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(232, 93, 4, 0.12);
}

.detail-card__section--contact {
  margin-top: 0;
}

.detail-card__label {
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
}

.detail-card__value {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}

.detail-card__location {
  padding: 4rpx 0;
  margin-top: 16rpx;
}

.detail-map {
  width: 100%;
  height: 360rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-card__value--link {
  color: var(--color-primary);
}

.detail-card__nav-hint {
  display: block;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.detail-swiper {
  height: 400rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-swiper__img {
  width: 100%;
  height: 100%;
  background: var(--color-bg);
}

.detail-video {
  width: 100%;
  height: 360rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.detail-rule {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  padding: 16rpx;
  background: var(--color-primary-bg);
  border-radius: 12rpx;
}

.detail-actions {
  padding: 24rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-actions__btn {
  width: 100%;
}

.detail-actions__hint {
  text-align: center;
  font-size: 24rpx;
  margin-top: 8rpx;
}
