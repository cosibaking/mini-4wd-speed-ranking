<view class="container" wx:if="{{track}}">
  <view class="card detail-header">
    <text class="detail-header__name">{{track.name}}</text>
    <text class="text-secondary">主理人：{{track.organizerName}}</text>
    <text class="text-secondary" wx:if="{{track.lengthMeters}}">赛道长度：{{track.lengthMeters}}米</text>
  </view>

  <view class="card">
    <view class="detail-row">
      <text class="detail-row__label">📍 位置</text>
      <text class="detail-row__value">{{track.location.address}}</text>
    </view>
    <button class="btn-secondary detail-nav-btn" bindtap="onNavigate">导航到赛道</button>
  </view>

  <view class="card" wx:if="{{track.floorPlanUrls.length > 0}}">
    <text class="section-title">平面图</text>
    <swiper class="detail-swiper" indicator-dots>
      <swiper-item wx:for="{{track.floorPlanUrls}}" wx:key="*this">
        <image class="detail-swiper__img" src="{{item}}" mode="aspectFit" />
      </swiper-item>
    </swiper>
  </view>

  <view class="card" wx:if="{{track.exampleVideoUrl || track.ruleNote}}">
    <text class="section-title">成绩认定说明</text>
    <video wx:if="{{track.exampleVideoUrl}}" class="detail-video" src="{{track.exampleVideoUrl}}" controls />
    <text class="detail-rule" wx:if="{{track.ruleNote}}">{{track.ruleNote}}</text>
  </view>

  <view class="card" wx:if="{{track.organizerContact}}">
    <view class="detail-row">
      <text class="detail-row__label">联系主理人</text>
      <text class="detail-row__value link" bindtap="onCopyContact">{{track.organizerContact}}（点击复制）</text>
    </view>
  </view>

  <view class="detail-actions">
    <button class="btn-primary detail-actions__btn" bindtap="onViewLeaderboard">查看圈速榜</button>
    <button class="btn-secondary detail-actions__btn" bindtap="onSubmitRecord">上传我的成绩</button>
  </view>
</view>

<view class="loading-tip text-secondary" wx:if="{{loading}}">加载中…</view>
