.edit-steps {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 0 8rpx;
}

.edit-step {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  flex: 1;
  text-align: center;
}

.edit-step--active {
  color: var(--color-primary);
  font-weight: 600;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  height: 88rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 88rpx;
}

.form-input--readonly {
  color: var(--color-text-secondary);
  background: #f0f0f0;
}

.form-map {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-btn);
  overflow: hidden;
  border: 2rpx solid var(--color-border);
}

.form-map-footer {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.form-map-hint {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.form-map-hint--empty {
  color: var(--color-text-placeholder);
}

.form-map-search {
  flex-shrink: 0;
  margin: 0;
}

.form-images {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.form-images__item {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-btn);
}

.form-images__add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-btn);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--color-text-placeholder);
}

.form-video {
  width: 100%;
  height: 300rpx;
  margin-top: 16rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  padding: 20rpx;
  border: 2rpx solid var(--color-border);
  box-sizing: border-box;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0 48rpx;
}

.edit-actions__btn {
  flex: 1;
}
