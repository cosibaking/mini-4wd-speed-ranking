.post-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 24rpx;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.post-author__profile {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.post-author__avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-border);
  flex-shrink: 0;
}

.post-author__name {
  font-size: 28rpx;
}

.follow-btn {
  margin-left: auto;
  background: var(--color-primary) !important;
  color: #fff !important;
}

.post-content {
  font-size: 28rpx;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

.post-images {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
}

.post-images__item {
  width: 100%;
  display: block;
  min-height: 200rpx;
  border-radius: var(--radius-btn);
  background: var(--color-border);
}

.post-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
}

.post-actions__item {
  font-size: 26rpx;
}

.post-actions__share {
  margin-left: auto;
}

.comment-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.comment-item--reply {
  margin-left: 32rpx;
  padding-left: 24rpx;
  border-left: 4rpx solid var(--color-border);
}

.comment-item__author-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.comment-item__avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-border);
  flex-shrink: 0;
}

.comment-item__author {
  font-weight: 600;
  font-size: 26rpx;
}

.comment-item__content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.comment-item__reply-to {
  color: var(--color-primary);
}

.comment-item__images {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.comment-item__image {
  width: 160rpx;
  height: 160rpx;
  display: block;
  border-radius: var(--radius-btn);
  background: var(--color-border);
}

.comment-item__actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 8rpx;
}

.comment-item__action {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-bar__reply-hint {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comment-bar__reply-text {
  color: var(--color-primary);
}

.comment-bar__cancel-reply {
  color: var(--color-text-secondary);
  padding: 4rpx 8rpx;
}

.comment-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--color-border);
}

.comment-bar__previews {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.comment-bar__preview {
  width: 96rpx;
  height: 96rpx;
  display: block;
  flex-shrink: 0;
  border-radius: var(--radius-btn);
  background: var(--color-border);
}

.comment-bar__row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comment-bar__input {
  flex: 1;
  background: var(--color-bg);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.comment-bar__image-btn {
  font-size: 40rpx;
  line-height: 1;
  padding: 4rpx;
}

.comment-bar__send {
  background: var(--color-primary) !important;
  color: #fff !important;
}

.post-page {
  padding-bottom: 180rpx;
}

.loading-tip {
  text-align: center;
  padding: 80rpx;
}
