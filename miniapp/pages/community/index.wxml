<nav-bar title="社区" />
<view class="container community-page">
  <view class="board-tabs-wrap">
    <scroll-view scroll-x class="board-tabs" enhanced show-scrollbar="{{false}}">
      <view
        class="board-tab {{activeBoardId === item.id ? 'board-tab--active' : ''}}"
        wx:for="{{boards}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onBoardTap"
      >{{item.name}}</view>
    </scroll-view>
  </view>

  <view class="sort-bar card card--flat">
    <text class="sort-item {{sort === 'latest' ? 'sort-item--active' : ''}}" data-sort="latest" bindtap="onSortTap">最新</text>
    <text class="sort-divider">|</text>
    <text class="sort-item {{sort === 'hot' ? 'sort-item--active' : ''}}" data-sort="hot" bindtap="onSortTap">热门</text>
  </view>

  <block wx:if="{{posts.length > 0}}">
    <post-card wx:for="{{posts}}" wx:key="id" post="{{item}}" />
  </block>

  <empty-state
    wx:if="{{!loading && posts.length === 0}}"
    title="暂无帖子"
    desc="分享赛道见闻、改装心得或新手问题"
    actionText="发帖"
    bind:action="onCreatePost"
  />

  <view class="fab" bindtap="onCreatePost">
    <text class="fab__icon">✎</text>
    <text class="fab__text">发帖</text>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">加载中…</view>
</view>
