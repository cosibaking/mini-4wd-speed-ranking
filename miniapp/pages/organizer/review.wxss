.review-status {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.review-status--pending {
  color: #b45309;
  background: #fef3c7;
}

.review-status--approved {
  color: #16a34a;
  background: #dcfce7;
}

.review-status--rejected {
  color: #dc2626;
  background: #fee2e2;
}

.review-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.review-user__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.review-user__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.review-video {
  width: 100%;
  height: 400rpx;
}

.config-img {
  width: 100%;
}

.photo-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.photo-grid__item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-btn);
}

.review-actions__note {
  margin-top: 24rpx;
}

.review-actions__input {
  margin-top: 12rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
}

.review-actions__btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}

.loading-tip {
  text-align: center;
  padding: 80rpx;
}

.reject-modal {
  position: fixed;
  inset: 0;
  z-index: 100;
}

.reject-modal__mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
}

.reject-modal__panel {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 32rpx;
}

.reject-modal__textarea {
  width: 100%;
  min-height: 160rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  box-sizing: border-box;
}

.reject-modal__btns {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.reject-modal__btns button {
  flex: 1;
}
