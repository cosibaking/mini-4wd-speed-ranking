.status-page {
  padding-top: 24rpx;
}

.status-card {
  padding: 32rpx;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.status-badge--pending {
  background: #fef3c7;
  color: #b45309;
}

.status-badge--approved {
  background: #dcfce7;
  color: #15803d;
}

.status-badge--rejected {
  background: #fee2e2;
  color: #b91c1c;
}

.status-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.status-label {
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.status-value {
  font-size: 26rpx;
  max-width: 60%;
  text-align: right;
}

.status-note {
  margin-top: 24rpx;
}

.status-hint {
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

