.leaderboard-page {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

.lb-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.lb-header__select {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.lb-header__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.lb-header__text {
  flex: 1;
  min-width: 0;
}

.lb-header__label {
  display: block;
  font-size: 22rpx;
  margin-bottom: 4rpx;
}

.lb-header__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lb-header__arrow {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.lb-header__stat {
  text-align: center;
  flex-shrink: 0;
}

.lb-header__count {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.lb-picker__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 28rpx;
}

.lb-picker__item:last-child {
  border-bottom: none;
}

.lb-picker__item--active {
  color: var(--color-primary);
  font-weight: 600;
}

.lb-picker__check {
  color: var(--color-primary);
  font-weight: 700;
}

.lb-list {
  padding: 0;
  overflow: hidden;
}

.lb-list record-row:last-child .record-row {
  border-bottom: none;
}

.lb-my-rank {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(250, 248, 245, 0) 0%, rgba(250, 248, 245, 0.95) 24%, #FAF8F5 100%);
  z-index: 10;
}

.lb-my-rank__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #fff;
  border-radius: var(--radius-card);
  padding: 24rpx 32rpx;
  box-shadow: var(--shadow-float);
  border: 2rpx solid var(--color-primary-bg);
}

.lb-my-rank__label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.lb-my-rank__value {
  font-size: 28rpx;
  font-weight: 600;
}

.lb-my-rank__time {
  font-size: 32rpx;
  margin-left: auto;
}
