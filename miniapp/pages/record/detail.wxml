<nav-bar title="成绩详情" />
<view class="container" wx:if="{{record}}">
  <view class="status-bar status-bar--{{record.status}}">
    <text wx:if="{{record.status === 'pending'}}">审核中</text>
    <text wx:elif="{{record.status === 'approved'}}">已认证</text>
    <text wx:else>未通过</text>
  </view>

  <view class="status-detail" wx:if="{{record.status === 'pending' || record.reviewNote}}">
    <text class="status-detail__hint text-secondary" wx:if="{{record.status === 'pending'}}">等待主理人认证，暂不上榜</text>
    <text class="status-detail__note" wx:if="{{record.reviewNote}}">主理人留言：{{record.reviewNote}}</text>
  </view>

  <view class="card record-header">
    <view class="record-header__user">
      <image class="record-header__avatar" src="{{record.user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
      <view>
        <text class="record-header__name">{{record.user.nickName}}</text>
        <text class="text-secondary record-header__track">{{record.trackName}}</text>
      </view>
    </view>
    <view class="record-header__stats" wx:if="{{record.status === 'approved'}}">
      <text class="record-header__rank" wx:if="{{record.isBestRecord && record.rank}}">当前排名：第 {{record.rank}} 名</text>
      <text class="record-header__time lap-time">{{record.lapTimeDisplay}}</text>
    </view>
    <view class="record-header__stats" wx:else>
      <text class="record-header__time lap-time">{{record.submittedLapTimeDisplay}}</text>
    </view>
    <text class="text-secondary record-header__corrected" wx:if="{{record.timeCorrected}}">
      提交圈速：{{record.submittedLapTimeDisplay}} → 认定：{{record.lapTimeDisplay}}
    </text>
    <text class="text-secondary">提交于 {{record.createdAt}}</text>
  </view>

  <view class="card">
    <text class="section-title">成绩认定视频</text>
    <video wx:if="{{record.videoUrl}}" class="detail-video" src="{{record.videoUrl}}" controls />
    <text class="text-secondary" wx:else>暂无视频</text>
  </view>

  <view class="card" wx:if="{{record.configSheet}}">
    <text class="section-title">车型配置单</text>
    <text wx:if="{{record.configSheet.type === 'text'}}">{{record.configSheet.content}}</text>
    <image wx:if="{{record.configSheet.type === 'image'}}" class="config-img" src="{{record.configSheet.url}}" mode="widthFix" />
  </view>

  <view class="card" wx:if="{{record.carPhotoUrls.length > 0}}">
    <text class="section-title">车辆照片</text>
    <view class="photo-grid">
      <image wx:for="{{record.carPhotoUrls}}" wx:key="*this" class="photo-grid__item" src="{{item}}" mode="aspectFill" />
    </view>
  </view>

  <view class="card" wx:if="{{record.note}}">
    <text class="section-title">备注</text>
    <text>{{record.note}}</text>
  </view>

  <button
    class="record-share-btn"
    wx:if="{{record.status === 'approved'}}"
    open-type="share"
  >分享给微信好友</button>
</view>

<view class="loading-tip text-secondary" wx:if="{{loading}}">加载中…</view>
