.record-header__user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.record-header__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.record-header__name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}

.record-header__track {
  font-size: 24rpx;
}

.record-header__stats {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.record-header__rank {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.record-header__time {
  font-size: 40rpx;
}

.detail-video {
  width: 100%;
  height: 400rpx;
}

.config-img {
  width: 100%;
}

.photo-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.photo-grid__item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-btn);
}

.loading-tip {
  text-align: center;
  padding: 80rpx;
}
