.record-header__user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.record-header__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border);
}

.record-header__name {
  font-size: 30rpx;
  font-weight: 600;
  display: block;
}

.record-header__track {
  font-size: 24rpx;
}

.record-header__stats {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.record-header__rank {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.record-header__time {
  font-size: 40rpx;
}

.record-header__corrected {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.status-bar {
  padding: 20rpx 24rpx;
  border-radius: var(--radius-card);
  margin-bottom: 20rpx;
  font-size: 26rpx;
  text-align: center;
}

.status-bar--pending {
  background: #fef3c7;
  color: #b45309;
}

.status-bar--approved {
  background: #dcfce7;
  color: #16a34a;
}

.status-bar--rejected {
  background: #fee2e2;
  color: #dc2626;
}

.status-detail {
  margin: -8rpx 0 20rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.status-detail__hint,
.status-detail__note {
  display: block;
}

.status-detail__note {
  margin-top: 8rpx;
  color: var(--color-text);
}

.detail-video {
  width: 100%;
  height: 400rpx;
}

.config-img {
  width: 100%;
}

.photo-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.photo-grid__item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-btn);
}

.loading-tip {
  text-align: center;
  padding: 80rpx;
}

.record-share-btn {
  margin: 8rpx 0 0;
  padding: 24rpx;
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  line-height: 1.4;
}

.record-share-btn::after {
  border: none;
}
