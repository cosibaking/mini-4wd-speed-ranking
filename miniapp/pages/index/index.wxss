.index-header {
  text-align: center;
  padding: 48rpx 0 64rpx;
}

.index-header__logo {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.index-header__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.index-header__subtitle {
  display: block;
  margin-top: 12rpx;
}

.index-entries {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 48rpx;
}

.entry-btn {
  padding: 40rpx 32rpx;
  border-radius: var(--radius-card);
  text-align: left;
  border: none;
}

.entry-btn::after {
  border: none;
}

.entry-btn--primary {
  background: var(--color-primary);
  color: #fff;
}

.entry-btn--secondary {
  background: #fff;
  color: var(--color-text);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.entry-btn__title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
}

.entry-btn__desc {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 8rpx;
}

.index-recent__scroll {
  white-space: nowrap;
}

.index-recent__list {
  display: inline-flex;
  gap: 16rpx;
}

.index-recent__item {
  display: inline-block;
  width: 480rpx;
}

.index-recent__item .track-card {
  margin-bottom: 0;
}
