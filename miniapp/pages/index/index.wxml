<view class="index-page">
  <image class="index-bg" src="/assets/home-bg.png" mode="aspectFill" />
  <view class="index-mask"></view>

  <view class="index-content" style="padding-top: {{topPadding}}px">
    <view class="index-spacer"></view>

    <view class="index-entries">
      <button class="entry-btn entry-btn--primary" bindtap="onOrganizerTap">
        <view class="entry-btn__icon entry-btn__icon--light">🛤</view>
        <view class="entry-btn__body">
          <text class="entry-btn__title">我是主理人</text>
          <text class="entry-btn__desc">申请认证 · 创建赛道</text>
        </view>
        <text class="entry-btn__chevron">›</text>
      </button>
      <button class="entry-btn entry-btn--secondary" bindtap="onDriverTap">
        <view class="entry-btn__icon">🏎</view>
        <view class="entry-btn__body">
          <text class="entry-btn__title">我是车手</text>
          <text class="entry-btn__desc">选择赛道 · 挑战圈速榜</text>
        </view>
        <text class="entry-btn__chevron">›</text>
      </button>
      <button class="entry-btn entry-btn--admin" wx:if="{{showAdminEntry}}" bindtap="onAdminTap">
        <view class="entry-btn__icon entry-btn__icon--admin">⚙</view>
        <view class="entry-btn__body">
          <text class="entry-btn__title">管理后台</text>
          <text class="entry-btn__desc">主理人审核 · 赛道与用户管理</text>
        </view>
        <text class="entry-btn__chevron">›</text>
      </button>
    </view>

    <view class="index-recent" wx:if="{{recentTracks.length > 0}}">
      <view class="index-recent__head">
        <text class="index-recent__title">最近赛道</text>
        <text class="index-recent__more" bindtap="onDriverTap">全部 ›</text>
      </view>
      <scroll-view scroll-x class="index-recent__scroll" enhanced show-scrollbar="{{false}}">
        <view class="index-recent__list">
          <view class="index-recent__item" wx:for="{{recentTracks}}" wx:key="id">
            <track-card track="{{item}}" showDistance="{{false}}" theme="dark" requireLogin="{{true}}" />
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
