.profile-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, var(--color-primary-bg) 100%);
}

.profile-avatar__btn {
  padding: 0;
  margin: 0 0 16rpx;
  background: transparent;
  border: none;
  line-height: normal;
  overflow: visible;
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  align-self: center;
}

.profile-avatar__btn::after {
  border: none;
}

.profile-avatar__img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-border);
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-card);
  display: block;
}

.profile-avatar__hint {
  font-size: 24rpx;
}

.profile-form {
  padding: 8rpx 0;
  overflow: hidden;
}

.profile-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  font-size: 30rpx;
}

.profile-field--edit {
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}

.profile-field__label {
  font-weight: 600;
  flex-shrink: 0;
}

.profile-field__value {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-text-secondary);
  min-width: 0;
}

.profile-field__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
}

.profile-field__input {
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  font-size: 30rpx;
}

.profile-field__actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.profile-field__btn {
  margin: 0;
  min-width: 120rpx;
}

.profile-field--bio {
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
}

.profile-field__value--bio {
  justify-content: space-between;
  align-items: flex-start;
  line-height: 1.5;
}

.profile-field--bio-edit {
  gap: 12rpx;
}

.profile-field__textarea {
  background: var(--color-bg);
  border-radius: var(--radius-btn);
  padding: 20rpx 24rpx;
  border: 2rpx solid var(--color-border);
  font-size: 28rpx;
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

.profile-field__counter {
  font-size: 24rpx;
  text-align: right;
}
