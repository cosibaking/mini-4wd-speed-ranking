.message-detail__card {
  padding: 32rpx 28rpx;
}

.message-detail__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.message-detail__type {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.message-detail__time {
  font-size: 24rpx;
}

.message-detail__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.message-detail__content {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--color-text);
  white-space: pre-wrap;
  word-break: break-word;
}

.loading-tip {
  padding: 80rpx 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}
