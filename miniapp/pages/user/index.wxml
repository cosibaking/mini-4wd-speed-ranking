<nav-bar title="我的" />
<view class="container user-page">
  <view class="user-header card user-header--clickable" wx:if="{{loggedIn && user}}" bindtap="onEditProfile">
    <image class="user-header__avatar" src="{{user.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
    <view class="user-header__info">
      <text class="user-header__name">{{user.nickName || '微信用户'}}</text>
      <text class="user-header__badge tag" wx:if="{{user.isOrganizer}}">赛道主理人</text>
      <text class="user-header__badge tag tag--admin" wx:if="{{user.isAdmin}}">管理员</text>
      <text class="user-header__hint text-secondary" wx:else>四驱车手</text>
    </view>
    <text class="user-header__arrow">›</text>
  </view>

  <view class="user-header card user-header--guest" wx:else>
    <button class="btn-primary user-header__login" bindtap="onLogin">微信登录</button>
    <text class="user-header__guest-hint text-secondary">登录后可上传成绩、发帖互动等</text>
  </view>

  <view class="menu card">
    <view class="menu-item" data-url="/pages/user/messages" bindtap="onNav" wx:if="{{loggedIn}}">
      <view class="menu-item__left">
        <text class="icon-badge">✉</text>
        <text>站内信</text>
        <text class="menu-item__badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item menu-item--admin" data-url="/admin/pages/index/index" bindtap="onNav" wx:if="{{loggedIn && user && user.isAdmin}}">
      <view class="menu-item__left">
        <text class="icon-badge">⚙</text>
        <text>管理后台</text>
        <view class="menu-item__dot" wx:if="{{adminHasPending}}"></view>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/user/tracks" bindtap="onNav">
      <view class="menu-item__left">
        <text class="icon-badge">🛤</text>
        <text>我管理的赛道</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/user/records" bindtap="onNav">
      <view class="menu-item__left">
        <text class="icon-badge">⏱</text>
        <text>我的成绩</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/user/following" bindtap="onNav">
      <view class="menu-item__left">
        <text class="icon-badge">★</text>
        <text>我的关注</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item menu-item--highlight" data-url="/pages/organizer/apply" bindtap="onNav" wx:if="{{loggedIn && user && !user.isOrganizer}}">
      <view class="menu-item__left">
        <text class="icon-badge">📝</text>
        <text>申请赛道主理人</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
    <view class="menu-item menu-item--highlight" data-url="/pages/track/edit" bindtap="onNav" wx:if="{{loggedIn && user && user.isOrganizer}}">
      <view class="menu-item__left">
        <text class="icon-badge">＋</text>
        <text>新建赛道</text>
      </view>
      <text class="menu-item__arrow">›</text>
    </view>
  </view>

  <view class="menu card" wx:if="{{loggedIn}}">
    <view class="menu-item menu-item--logout" bindtap="onLogout">
      <view class="menu-item__left">
        <text class="icon-badge icon-badge--logout">⏻</text>
        <text class="menu-item__logout-text">退出登录</text>
      </view>
    </view>
  </view>
</view>
