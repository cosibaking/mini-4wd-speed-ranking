<nav-bar title="我的成绩" />
<view class="container">
  <view class="record-item card" wx:for="{{records}}" wx:key="id" data-id="{{item.id}}" bindtap="onTap">
    <view class="record-item__header">
      <view class="record-item__left">
        <text class="record-item__track">{{item.trackName || '赛道'}}</text>
        <text class="record-item__badge record-item__badge--{{item.status}}">{{statusLabel[item.status]}}</text>
      </view>
      <text class="record-item__time lap-time">{{item.status === 'approved' ? item.lapTimeDisplay : item.submittedLapTimeDisplay}}</text>
    </view>
    <text class="text-secondary">{{item.createdAt}}</text>
    <text class="text-secondary" wx:if="{{item.status === 'approved' && item.rank}}">排名：第 {{item.rank}} 名</text>
    <text class="record-item__reject text-secondary" wx:if="{{item.status === 'rejected' && item.reviewNote}}">{{item.reviewNote}}</text>
  </view>

  <empty-state
    wx:if="{{!loading && records.length === 0}}"
    title="暂无成绩"
    desc="去赛道挑战你的第一个圈速吧"
    actionText="选择赛道"
    bind:action="onGoTracks"
  />
</view>
