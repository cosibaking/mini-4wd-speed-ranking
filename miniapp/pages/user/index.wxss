.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, var(--color-primary-bg) 100%);
}

.user-header--guest {
  flex-wrap: wrap;
}

.user-header--clickable:active {
  opacity: 0.85;
}

.user-header__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
  flex-shrink: 0;
}

.user-header__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-border);
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-card);
  flex-shrink: 0;
}

.user-header__avatar--guest {
  opacity: 0.7;
}

.user-header__info {
  flex: 1;
  min-width: 0;
}

.user-header__name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.user-header__badge {
  display: inline-block;
  margin-right: 8rpx;
}

.tag--admin {
  background: #1a1208;
  color: #fff;
}

.user-header__hint {
  display: block;
  font-size: 24rpx;
}

.user-header__login {
  width: 100%;
  margin-top: 16rpx;
}

.menu {
  padding: 8rpx 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item--highlight {
  background: rgba(255, 247, 237, 0.6);
}

.menu-item--admin {
  background: rgba(26, 18, 8, 0.06);
}

.menu-item__left {
  display: flex;
  align-items: center;
}

.menu-item__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
}
