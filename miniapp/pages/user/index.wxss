.user-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 28rpx;
  background: linear-gradient(135deg, #fff 0%, var(--color-primary-bg) 100%);
}

.user-header--guest {
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 32rpx 40rpx;
  text-align: center;
}

.user-header--clickable:active {
  opacity: 0.85;
}

.user-header__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
  flex-shrink: 0;
}

.user-header__avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-border);
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-card);
  flex-shrink: 0;
}

.user-header__info {
  flex: 1;
  min-width: 0;
}

.user-header__name {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
}

.user-header__badge {
  display: inline-block;
  margin-right: 8rpx;
}

.tag--admin {
  background: #1a1208;
  color: #fff;
}

.user-header__hint {
  display: block;
  font-size: 24rpx;
  line-height: 1.4;
}

.user-header__guest-hint {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-placeholder);
}

.user-header__login {
  width: 100%;
  max-width: 480rpx;
  margin: 0;
  padding: 0 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(232, 93, 4, 0.28);
}

.menu {
  padding: 8rpx 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item--highlight {
  background: rgba(255, 247, 237, 0.6);
}

.menu-item--admin {
  background: rgba(26, 18, 8, 0.06);
}

.menu-item--logout {
  justify-content: center;
}

.menu-item--logout .menu-item__left {
  gap: 8rpx;
}

.menu-item__logout-text {
  color: #e64340;
  font-weight: 600;
}

.icon-badge--logout {
  color: #e64340;
}

.menu-item__left {
  display: flex;
  align-items: center;
}

.menu-item__dot {
  margin-left: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff3b30;
  flex-shrink: 0;
}

.menu-item__badge {
  margin-left: 12rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

.menu-item__arrow {
  color: var(--color-text-placeholder);
  font-size: 32rpx;
}
