page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-page {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  background: var(--color-bg);
}

.picker-search {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
}

.picker-search__input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
}

.picker-search__btn {
  flex-shrink: 0;
  margin: 0;
}

.picker-map {
  width: 100%;
  height: 420rpx;
  flex-shrink: 0;
}

.picker-results {
  flex: 1;
  min-height: 0;
  background: var(--color-card);
}

.picker-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.picker-result--active {
  background: var(--color-primary-bg);
}

.picker-result__main {
  flex: 1;
  min-width: 0;
}

.picker-result__name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.picker-result__address {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.picker-result__check {
  flex-shrink: 0;
  color: var(--color-primary);
  font-size: 32rpx;
  font-weight: 700;
}

.picker-empty {
  padding: 48rpx 32rpx;
  text-align: center;
  color: var(--color-text-placeholder);
  font-size: 26rpx;
}

.picker-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--color-card);
  border-top: 1rpx solid var(--color-border);
}

.picker-actions__btn {
  flex: 1;
  margin: 0;
}
