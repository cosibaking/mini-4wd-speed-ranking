.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
  padding: 8rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-card);
}

.search-bar__icon {
  font-size: 28rpx;
  opacity: 0.5;
}

.search-bar__input {
  flex: 1;
  padding: 16rpx 0;
  font-size: 28rpx;
  background: transparent;
}

.user-item {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.user-item__head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-item__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: var(--color-border);
}

.user-item__info {
  flex: 1;
}

.user-item__name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.user-item__badge {
  display: inline-block;
  margin-top: 8rpx;
  margin-right: 8rpx;
}

.tag--muted {
  background: #f3f4f6;
  color: #6b7280;
}

.user-item__actions {
  display: flex;
  gap: 16rpx;
}
