<nav-bar title="用户管理" />
<view class="container">
  <view class="search-bar">
    <text class="search-bar__icon">🔍</text>
    <input
      class="search-bar__input"
      placeholder="搜索用户昵称"
      value="{{keyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
    />
  </view>
  <view wx:for="{{list}}" wx:key="id" class="card user-item">
    <view class="user-item__head" bindtap="onOpenUser" data-id="{{item.id}}">
      <image class="user-item__avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-item__info">
        <text class="user-item__name">{{item.nickName || '微信用户'}}</text>
        <text class="user-item__badge tag" wx:if="{{item.isOrganizer}}">已认证主理人</text>
        <text class="user-item__badge tag tag--muted" wx:if="{{item.adminRole}}">管理员</text>
      </view>
    </view>
    <view class="user-item__actions">
      <button
        class="btn-secondary"
        size="mini"
        data-id="{{item.id}}"
        data-name="{{item.nickName}}"
        data-avatar="{{item.avatarUrl}}"
        bindtap="onSendMessage"
      >发站内信</button>
      <button
        wx:if="{{!item.adminRole}}"
        class="btn-primary"
        size="mini"
        data-id="{{item.id}}"
        bindtap="onGrantAdmin"
      >授予管理员</button>
      <button
        wx:elif="{{!item.isSystemAdmin}}"
        class="btn-secondary"
        size="mini"
        data-id="{{item.id}}"
        bindtap="onRevokeAdmin"
      >撤销管理员</button>
      <button
        wx:if="{{!item.isOrganizer}}"
        class="btn-primary"
        size="mini"
        data-id="{{item.id}}"
        bindtap="onGrant"
      >授予主理人</button>
      <button
        wx:else
        class="btn-secondary"
        size="mini"
        data-id="{{item.id}}"
        bindtap="onRevoke"
      >撤销主理人</button>
    </view>
  </view>
  <empty-state
    wx:if="{{!loading && list.length === 0}}"
    title="{{keyword ? '未找到匹配用户' : '暂无用户'}}"
  />
</view>
