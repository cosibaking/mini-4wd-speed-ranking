.admin-home {
  padding-top: 24rpx;
}

.admin-stats {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
  margin-bottom: 24rpx;
}

.admin-stat {
  text-align: center;
}

.admin-stat__num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.admin-stat__label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.admin-menu__item {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.admin-menu__item:last-child {
  border-bottom: none;
}

.admin-menu__title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
}

.admin-menu__desc {
  width: 100%;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.admin-menu__chevron {
  font-size: 36rpx;
  color: var(--color-text-placeholder);
}
