{
  "name": "mini-4wd-speed-ranking",
  "private": true,
  "workspaces": [
    "server",
    "miniapp"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "build": "npm run build:server",
    "dev:server": "npm run dev -w server",
    "compile:miniapp": "npm run compile -w miniapp",
    "build:server": "npm run build -w server",
    "db:migrate": "npm run build -w server && npm run db:migrate -w server",
    "db:seed": "npm run build -w server && npm run db:seed -w server",
    "db:clear": "bash scripts/clear-all-data.sh",
    "db:clear-tracks": "bash scripts/clear-all-tracks.sh",
    "db:clear-posts": "bash scripts/clear-all-posts.sh",
    "db:clear-mock-posts": "bash scripts/clear-mock-posts.sh",
    "deploy:82": "bash scripts/deploy-to-82.sh"
  },
  "engines": {
    "node": ">=20"
  }
}
