# =============================================================================
# 微信云托管环境变量模板（在控制台 → 服务 → 版本配置 → 环境变量 中填写）
# 复制 82 服务器 /home/ubuntu/mini-4wd-speed-ranking-old/server/.env 的值，按下方说明修改
# =============================================================================

NODE_ENV=production
# 云托管默认服务端口 80，须与 Dockerfile EXPOSE 一致
PORT=80

# 【必改】把 127.0.0.1 换成 82 公网 IP，云托管容器才能连到 82 上的 MySQL
DATABASE_URL="mysql://mini4wd:你的密码@82.156.54.232:3306/mini4wd"

# 【留空】82 的 Redis 只监听 127.0.0.1，云托管连不上；后端会自动降级（无缓存/无限流）
REDIS_URL=

JWT_SECRET=从82复制
JWT_EXPIRES_IN=604800

WECHAT_APP_ID=wx5f2fd509dc0857cc
WECHAT_APP_SECRET=从82复制
WECHAT_MOCK=false
WECHAT_REALNAME_MOCK=true

ADMIN_OPEN_IDS=从82复制

COS_SECRET_ID=从82复制
COS_SECRET_KEY=从82复制
COS_BUCKET=mini-4wd-1333410420
COS_REGION=ap-beijing
CDN_BASE_URL=从82复制
MEDIA_ENV_PREFIX=prod
MEDIA_MOCK=false

TENCENT_MAP_KEY=从82复制
TENCENT_MAP_SK=从82复制
