# =============================================================================
# 生产环境配置模板
# 用法：复制为 .env 后填入真实值，勿提交到 git
#   cp .env.production.example .env
# =============================================================================

# --- 基础 ---
NODE_ENV=production
PORT=3000

# --- 数据库（腾讯云 RDS MySQL 8）---
# 格式：mysql://用户名:密码@主机:端口/库名
DATABASE_URL="mysql://USER:PASSWORD@rm-xxxxx.mysql.rds.aliyuncs.com:3306/mini4wd"

# --- Redis（建议启用：榜单缓存 + 发帖/评论/上传限流）---
REDIS_URL="redis://:PASSWORD@r-xxxxx.redis.rds.aliyuncs.com:6379/0"

# --- JWT ---
# 必须使用 ≥32 字符的随机串，与开发环境隔离
JWT_SECRET="REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARS"
JWT_EXPIRES_IN=604800

# --- 微信小程序 ---
WECHAT_APP_ID="wxYOUR_APP_ID"
WECHAT_APP_SECRET="YOUR_APP_SECRET"
# 生产环境不要设置 WECHAT_MOCK（登录使用真实openid）
WECHAT_MOCK=false
# 生产环境不要设置 WECHAT_REALNAME_MOCK
WECHAT_REALNAME_MOCK=false
# 生产环境不要设置 MOCK_LOGIN_CODE

# --- 管理员（逗号分隔 openId，登录后自动获得 admin 角色）---
ADMIN_OPEN_IDS="oXXXX_admin_openid_1,oXXXX_admin_openid_2"

# --- 腾讯云 COS（媒体上传/播放）---
COS_SECRET_ID="AKIDxxxxxxxx"
COS_SECRET_KEY="xxxxxxxx"
COS_BUCKET="mini-4wd-1333410420"
COS_REGION="ap-beijing"
# 媒体对外 URL 前缀（无末尾 /）。二选一：
# 方案 A（推荐上线）：CDN 加速域名
# CDN_BASE_URL="https://cdn.example.com"
# 方案 B（MVP 无 CDN）：COS 默认 HTTPS 域名，桶须设为「公有读私有写」，详见 docs/生产配置使用说明.md §4
CDN_BASE_URL="https://mini-4wd-1333410420.cos.ap-beijing.myqcloud.com"
MEDIA_ENV_PREFIX=prod
MEDIA_MOCK=false

# --- 腾讯位置服务（服务端逆地理编码，选点搜索）---
# Key 在 https://lbs.qq.com 申请；SK 用于签名校验
TENCENT_MAP_KEY="YOUR_MAP_KEY"
TENCENT_MAP_SK="YOUR_MAP_SK"

# =============================================================================
# 生产环境请勿设置以下开发专用变量：
#   MOCK_LOGIN_CODE
#   MOCK_MEDIA_HOST
# =============================================================================
