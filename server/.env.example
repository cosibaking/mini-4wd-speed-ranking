# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="mysql://mini4wd:mini4wd@localhost:3306/mini4wd"

# Redis (optional — server degrades gracefully if unavailable)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN=604800

# WeChat Mini Program
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
# Dev mock: use code as openId for local testing
WECHAT_MOCK=true
# Dev mock: skip WeChat city service real-name API
WECHAT_REALNAME_MOCK=true
# Dev mock: fixed login code → openId mock_{code}，与 ADMIN_OPEN_IDS 对应
MOCK_LOGIN_CODE=admin

# Admin: comma-separated openIds for mini program developers/admins
ADMIN_OPEN_IDS="mock_admin"
